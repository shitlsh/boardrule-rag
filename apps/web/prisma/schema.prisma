generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  /// 应用表集中在 `app`，`public` 留给 LangGraph / LlamaIndex（pgvector 等）。
  schemas  = ["app"]
}

/// Board game metadata and extraction artifacts.
/// Path fields are object keys (Supabase Storage) or paths under apps/web/storage/ — never inline file bodies.
model Game {
  id                  String   @id @default(cuid())
  name                String
  slug                String   @unique
  coverUrl            String?
  version             Int      @default(0)
  rulesMarkdownPath   String?
  quickStartGuidePath String?
  startQuestionsPath  String?
  indexId             String?
  vectorStoreId       String?
  extractionStatus    String?
  extractionJobId     String?
  /// Rule engine job id from POST /extract/pages (page rasterization).
  pageRasterJobId     String?
  /// JSON string: [{ "pageNumber": n, "url": "...", "label": "Pn" }, ...]
  pagePreviewJson     String?
  pageMetadataEnabled Boolean  @default(true)
  lastCheckpointId    String?

  tasks Task[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@schema("app")
}

model Task {
  id           String @id @default(cuid())
  gameId       String
  game         Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)
  status       String
  type         String @default("EXTRACTION")
  errorMsg     String?
  progressJson String?
  jobId        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([gameId])
  @@schema("app")
}

/// Singleton row (`id = "default"`): ingestion limits and page raster hints for the rule engine.
model AppSettings {
  id String @id @default("default")

  maxImageBytes      Int @default(10485760) // 10 MiB
  maxPdfBytes        Int @default(52428800) // 50 MiB
  maxMultiImageFiles Int @default(60)
  maxPdfPages        Int @default(80)
  maxGstoneImageUrls Int @default(80)
  pageRasterDpi      Int @default(150)
  pageRasterMaxSide  Int @default(2048)
  /// JSON: LLM Gateway (credentials with encrypted keys, slot bindings). See lib/ai-gateway.ts.
  aiGatewayJson      String @default("{}")
  /// JSON: WeChat miniapp config (appId + encrypted appSecret). See lib/wechat-settings.ts.
  wechatConfigJson   String @default("{}")
  /// Max chat messages per WeChat user per day. 0 = unlimited.
  dailyChatLimit     Int    @default(20)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@schema("app")
}

/// Per-user daily chat usage counter. Key format: "wx:{openid}:{YYYY-MM-DD}".
model RateLimit {
  id        String   @id
  count     Int      @default(1)
  expiresAt DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@schema("app")
}
