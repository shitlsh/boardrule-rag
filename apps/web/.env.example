# Prisma ORM 7: URL is read by prisma.config.ts (and Next.js loads .env for the app).
# Local: `supabase start` then match `supabase status` (Postgres URL).
# The rule engine (`services/rule_engine`) needs the same `DATABASE_URL` in its own `.env` for LangGraph checkpoints.
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"

# Rule engine base URL (no trailing slash). Must match CORS on the engine.
RULE_ENGINE_URL="http://127.0.0.1:8000"

# Optional: Supabase Storage. If unset, files use apps/web/storage/ (gitignored).
# Buckets are created by supabase/migrations (`rulebook-raw`, `game-exports`).
# SUPABASE_URL="http://127.0.0.1:54321"
# SUPABASE_SERVICE_ROLE_KEY="<service_role JWT from `supabase status` or Dashboard → Settings → API>"
# Optional overrides if bucket ids differ from defaults:
# SUPABASE_STORAGE_BUCKET_RAW="rulebook-raw"
# SUPABASE_STORAGE_BUCKET_EXPORTS="game-exports"
