# =============================================================================
# apps/web — copy to `.env` (Next.js + Prisma). See repository root QUICKSTART.md.
# =============================================================================

# Prisma / Postgres (same URL as services/rule_engine DATABASE_URL for local Supabase).
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"

# Auth.js — generate with: npx auth secret
AUTH_SECRET="replace-with-output-of-npx-auth-secret"
# Same secret must be configured for production deployments.

# Supabase API — required for @auth/supabase-adapter and for Storage (same URL + service role).
SUPABASE_URL="http://127.0.0.1:54321"
SUPABASE_SERVICE_ROLE_KEY="<service_role JWT from supabase status or Dashboard → API>"
# Optional bucket names (defaults match supabase/migrations/):
# SUPABASE_STORAGE_BUCKET_RAW=rulebook-raw
# SUPABASE_STORAGE_BUCKET_EXPORTS=game-exports
# If SUPABASE_* is missing, uploads fall back to apps/web/storage/ on disk.

# Miniapp JWT (HS256) — long random string; must match BFF only.
MINIAPP_JWT_SECRET="replace-with-long-random-string"

# Rule engine base URL (no trailing slash). Must match rule_engine CORS_ORIGINS.
RULE_ENGINE_URL="http://127.0.0.1:8000"
# Hugging Face Space (production example — use your namespace and space slug):
# RULE_ENGINE_URL="https://youruser-your-space.hf.space"
# Shared secret; rule_engine must set the same value when RULE_ENGINE_API_KEY is set.
RULE_ENGINE_API_KEY="replace-with-long-random-string"

# Required: encrypts Gemini API keys stored in AppSettings (AI Gateway). Without this,
# saving credentials on /models will fail.
AI_CONFIG_SECRET="change-me-to-a-long-random-string"

# CORS for miniapp / H5 origin (see next.config.mjs). Use your production web URL when deploying.
# MINIAPP_ALLOWED_ORIGIN=https://your-web.vercel.app

# --- Optional: build metadata (settings page) ---
# NEXT_PUBLIC_BUILD_ID=dev
