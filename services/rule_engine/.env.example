# Gemini (Generative Language API) — required for extraction and RAG
GOOGLE_API_KEY=

# LangSmith (optional; set LANGCHAIN_TRACING_V2=true to enable)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=boardrule-rag

# LangGraph checkpoints: PostgreSQL only (PostgresSaver). Use the same DB as apps/web or override.
# Supabase local (`supabase start` — use `supabase status` for the exact URL):
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
# Optional: checkpoints only, if different from DATABASE_URL / index DB:
# RULE_ENGINE_CHECKPOINT_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# CORS: comma-separated origins for apps/web
CORS_ORIGINS=http://localhost:3000

# Public base URL for page thumbnail links returned by POST /extract/pages (optional; else relative /page-assets/...)
# RULE_ENGINE_PUBLIC_URL=http://127.0.0.1:8000

# Page rasterization (pdf2image + poppler); apps/web 系统设置可覆盖并随请求传入
PAGE_RASTER_DPI=150
PAGE_RASTER_MAX_SIDE=2048
# 未传 Form 时 extract 使用的默认上限（与 apps/web AppSettings 默认值一致）
# RULEBOOK_MAX_PAGES=80
# RULEBOOK_MAX_MULTI_IMAGE_FILES=60
# RULEBOOK_MAX_PDF_BYTES=52428800
# RULEBOOK_MAX_IMAGE_BYTES=10485760

# Vision batching: max physical pages per Gemini Pro call
# VISION_BATCH_PAGES=6
# When the model returns NEED_MORE_CONTEXT, adjacent batches may be merged up to this many pages per request
# GEMINI_VISION_MAX_MERGE_PAGES=24
# Max adjacent-batch merge steps per starting batch (NEED_MORE_CONTEXT retry loop)
# NEED_MORE_CONTEXT_MAX_EXPAND=8

# Optional Gemini model overrides (use vision-capable models for Pro)
# GEMINI_FLASH_MODEL=gemini-2.0-flash
# GEMINI_PRO_MODEL=gemini-1.5-pro
# GEMINI_PRO_MAX_OUTPUT_TOKENS=8192

# Phase 3: RAG chat (`POST /chat`)
# GEMINI_CHAT_MODEL=gemini-2.0-flash
# GEMINI_CHAT_TEMPERATURE=0.2
# GEMINI_CHAT_MAX_TOKENS=8192

# Phase 2: indexes — BM25 on disk; vectors in PostgreSQL when DATABASE_URL is set and USE_PGVECTOR is not disabled
# INDEX_STORAGE_ROOT=
# PGVECTOR_DATABASE_URL=   # optional override; defaults to DATABASE_URL
# USE_PGVECTOR=true
# EMBEDDING_DIM=3072

# GEMINI_EMBEDDING_MODEL=gemini-embedding-001
# RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
