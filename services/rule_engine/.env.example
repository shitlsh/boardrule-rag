# =============================================================================
# Rule engine — copy to `.env` (see README.md). Required keys must be set to run.
# =============================================================================

# Gemini API keys and model IDs are NOT configured here. The apps/web BFF sends
# ``X-Boardrule-Ai-Config`` on each request (see AI Gateway settings in the web UI).
#
# HTTP timeout for google-genai ``generate_content`` (milliseconds). Prevents indefinite hang when
# the network cannot reach Google (e.g. home firewall). Default 120000 in code; increase if vision calls legitimately need longer.
# GEMINI_HTTP_TIMEOUT_MS=300000

# LangGraph PostgresSaver (same DB as apps/web Prisma is typical).
# 端口须为数字或省略（用默认 5432）；勿写成字面量 ``:None``，否则建索引时 SQLAlchemy 会报错。
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# --- HTTP ---
# Browser origins allowed by FastAPI CORS (must include your apps/web origin).
CORS_ORIGINS=http://localhost:3000

# Logging for ``boardrule.*`` loggers (extract worker, POST /extract trace). Default INFO via code if unset.
# RULE_ENGINE_LOG_LEVEL=DEBUG

# Optional: absolute URLs for /page-assets/... links from POST /extract/pages (else relative).
# RULE_ENGINE_PUBLIC_URL=http://127.0.0.1:8000

# Optional: checkpoints only, if different from DATABASE_URL.
# RULE_ENGINE_CHECKPOINT_URL=

# --- LangSmith (optional; Gemini calls emit child runs only when tracing is on AND an API key is set) ---
LANGCHAIN_TRACING_V2=false
# LANGSMITH_TRACING_V2=true
LANGCHAIN_API_KEY=
# LANGSMITH_API_KEY=
# Project name in LangSmith UI (standard env; read by LangSmith client, not referenced in app code).
LANGCHAIN_PROJECT=boardrule-rag

# --- POST /extract/pages defaults (used when the multipart form omits the field) ---
# Web UI usually sends limits from DB AppSettings; these are engine-side fallbacks.
PAGE_RASTER_DPI=150
PAGE_RASTER_MAX_SIDE=2048
# RULEBOOK_MAX_PAGES=80
# RULEBOOK_MAX_MULTI_IMAGE_FILES=60
# RULEBOOK_MAX_PDF_BYTES=52428800
# RULEBOOK_MAX_IMAGE_BYTES=10485760

# --- Vision extraction (graphs/nodes) — see EXTRACTION_FLOW.md §2.1 ---
# Product gate: body pages ≤ this → simple profile (unless force_full_pipeline).
# EXTRACTION_SIMPLE_MAX_BODY_PAGES=10
# Complex-route only: OR into needs_batching when body pages exceed this.
# EXTRACTION_COMPLEX_ROUTE_BODY_PAGES=15
# VISION_BATCH_PAGES=6
# GEMINI_VISION_MAX_MERGE_PAGES=
# NEED_MORE_CONTEXT_MAX_EXPAND=8
# Warn when simple-path single batch covers more body pages than this (default 32).
# EXTRACTION_SIMPLE_PATH_WARN_BODY_PAGES=32

# --- POST /build-index/start (ingestion/index_builder.py) ---
# Embedding *model* id comes from apps/web AI Gateway (Embed slot) via X-Boardrule-Ai-Config.
# INDEX_STORAGE_ROOT=
# PGVECTOR_DATABASE_URL=
# USE_PGVECTOR=true
# (index_builder 会为 PGVectorStore 同时配置 psycopg2 与 asyncpg 连接串；勿依赖仅传一条 postgresql:// 的旧行为。)
# EMBEDDING_DIM=3072
# Default cross-encoder: BAAI/bge-reranker-base (multilingual; larger download than MiniLM). Override via RERANK_MODEL or Web /models → 检索与索引.
# RERANK_MODEL=BAAI/bge-reranker-base
# CHUNK_SIZE=1024
# CHUNK_OVERLAP=128
# Rebuild indexes after changing chunking, BM25, or metadata (see ingestion).

# --- Advanced local paths ---
# Override where /extract/pages writes PNGs (default: service data dir).
# PAGE_ASSETS_ROOT=
