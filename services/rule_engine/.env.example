# LlamaParse / Llama Cloud
LLAMA_CLOUD_API_KEY=

# Gemini (Generative Language API)
GOOGLE_API_KEY=

# LangSmith (optional; set LANGCHAIN_TRACING_V2=true to enable)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=boardrule-rag

# Optional: override LangSmith API endpoint
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# LangGraph checkpoint (SQLite path for dev; use Postgres saver in production)
CHECKPOINT_DB_PATH=checkpoints.sqlite

# CORS: comma-separated origins for apps/web
CORS_ORIGINS=http://localhost:3000

# Optional Gemini model overrides
# GEMINI_FLASH_MODEL=gemini-2.0-flash
# GEMINI_PRO_MODEL=gemini-1.5-pro
